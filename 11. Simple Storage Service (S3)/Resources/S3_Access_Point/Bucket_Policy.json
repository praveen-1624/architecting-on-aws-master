{
    "Version": "2012-10-17",
    "Statement": [
    {
        "Effect": "Allow",
        "Principal": {
            "AWS": "*"
        },
        "Action": "*",
        "Resource": [
            "<Bucket ARN>",
            "<Bucket ARN>/*"
        ],
        "Condition": {
            "StringEquals": {
                "s3:DataAccessPointAccount": "<AWS Account ID>"
                }
            }
        }
    ]
}