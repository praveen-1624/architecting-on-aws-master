{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowOnlySpecificIP",
            "Effect": "Allow",
            "Principal": "*",
            "Action": "execute-api:Invoke",
            "Resource": "arn:aws:execute-api:<region>:<your-account-id>:<your-api-id>/*/*/*",
            "Condition": {
                "IpAddress": {
                    "aws:SourceIp": "<allowed-ip>/32"
                }
            }
        }
    ]
}
